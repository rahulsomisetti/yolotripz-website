# Sanity (managed project / extracted schema)
.sanity

# Copy to .env.local — never commit secrets
.env.local

# Sanity — public (safe in browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity — server only (optional: read token for private datasets / preview)
SANITY_API_READ_TOKEN=

# Sanity — server only (required for website lead capture via /api/leads)
SANITY_API_WRITE_TOKEN=

# Optional: lock POST /api/leads to these site origins (comma-separated). Dev example:
# LEAD_FORM_ALLOWED_ORIGINS=http://localhost:3000
LEAD_FORM_ALLOWED_ORIGINS=

# Optional: canonical site URL(s) for documentation / future use
NEXT_PUBLIC_SITE_URL=

# --- Embedded Sanity Studio gate (/studio) — server only; never expose to client ---
# HS256 signing key; use a long random string (32+ characters).
STUDIO_GATE_SECRET=
# Shared access phrase for approved teammates (stored only on the server).
STUDIO_GATE_PASSWORD=
# Comma-separated allowlist of emails that may pass the gate (lowercased when matched).
STUDIO_GATE_ALLOWED_EMAILS=
